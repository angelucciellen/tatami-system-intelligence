//@version=5
// =============================================================================
// vX Rhythm Engine™ v0.4 — Fractal Synchronization Layer (syntax-fixed)
// =============================================================================
indicator("vX Rhythm Engine™ v0.4", shorttitle="vX RHYTHM·v0.4", overlay=true,
     max_lines_count=120, max_labels_count=50, max_boxes_count=120)

// ─── INPUTS ──────────────────────────────────────────────────────────────────
gC = "Adaptive Channel"
chanLen   = input.int(50,  "Channel Length",          minval=10, maxval=500, group=gC)
chanMult  = input.float(2.0,"Channel Width (σ mult)", minval=0.5, maxval=4.0, step=0.1, group=gC)
adaptive  = input.bool(true,"Adaptive Width (ATR-scaled)", group=gC)

gA = "ATR / Normalization"
atrLen    = input.int(14, "ATR Length",          minval=2,  group=gA)
atrSlow   = input.int(50, "ATR Baseline Length", minval=10, group=gA)

gB = "Behavioral Windows"
slopeWin    = input.int(5,  "Slope Window",     minval=2, group=gB)
cadenceLen  = input.int(10, "Cadence Window",   minval=3, group=gB)
effLen      = input.int(10, "Efficiency Window",minval=3, group=gB)
behaviorLen = input.int(10, "Behavior Window",  minval=5, group=gB)

gT = "State Thresholds"
qThresh = input.int(65, "Clean Traversal ≥",  minval=40, maxval=95, group=gT)
cThresh = input.int(65, "Compression Coil ≥", minval=40, maxval=95, group=gT)
xThresh = input.int(65, "Expansion Burst ≥",  minval=40, maxval=95, group=gT)
eThresh = input.int(70, "Exhaustion ≥",       minval=40, maxval=95, group=gT)

gF = "Fractal Sync"
htf1Tf       = input.timeframe("60",  "Higher TF 1",      group=gF)
htf2Tf       = input.timeframe("240", "Higher TF 2",      group=gF)
useHtf2      = input.bool(true,  "Enable HTF 2",          group=gF)
showHtf1     = input.bool(true,  "Show HTF1 rails",       group=gF)
showHtf2     = input.bool(false, "Show HTF2 rails",       group=gF)

gM = "Memory Zones"
showMemory  = input.bool(true,  "Show Memory Zones",        group=gM)
maxPerKind  = input.int(4,     "Max zones per type",       minval=1, maxval=10, group=gM)
decayPerBar = input.float(0.40,"Decay per bar (score)",    minval=0.05, step=0.05, group=gM)
touchBonus  = input.float(5.0, "Touch reinforcement",      minval=1.0, step=0.5, group=gM)
rejectBonus = input.float(10.0,"Rejection reinforcement",  minval=1.0, step=0.5, group=gM)
removeThresh= input.int(10,    "Removal threshold (score)",minval=0, maxval=50, group=gM)
spawnCool   = input.int(5,     "Spawn cooldown (bars)",    minval=0, group=gM)
memEquilOn  = input.bool(true, "Equilibrium memory",       group=gM)
memComprOn  = input.bool(true, "Compression memory",       group=gM)
memExpanOn  = input.bool(true, "Expansion origin",         group=gM)
memExhstOn  = input.bool(true, "Exhaustion memory",        group=gM)
memFailOn   = input.bool(true, "Failed traversal memory",  group=gM)

gL = "Pivot Liquidity"
pivotL    = input.int(5, "Pivot Left",  minval=1, group=gL)
pivotR    = input.int(5, "Pivot Right", minval=1, group=gL)
maxZones  = input.int(8, "Max pivot levels (each side)", minval=2, maxval=20, group=gL)
showZones = input.bool(true, "Show pivot liquidity lines", group=gL)

gV = "Visual"
showChannel = input.bool(true, "Channel",            group=gV)
showFill    = input.bool(true, "Channel fill",       group=gV)
showRibbon  = input.bool(true, "State ribbon (bg)",  group=gV)
colorBars   = input.bool(false,"Color bars by state",group=gV)
showDash    = input.bool(true, "Dashboard",          group=gV)
dashPos     = input.string("top_right", "Dashboard position", options=["top_left","top_right","bottom_left","bottom_right"], group=gV)

// ─── PALETTE ─────────────────────────────────────────────────────────────────
cMid     = color.new(#8a93a3, 50)
cRail    = color.new(#5c6370, 30)
cText    = color.new(#e5e7eb, 0)
cTextDim = color.new(#9aa0a6, 0)
cTextMute= color.new(#6b7280, 0)

cTraversal   = color.new(#06d6a0, 0)
cExpansion   = color.new(#3a86ff, 0)
cCompression = color.new(#f4d35e, 0)
cExhaustion  = color.new(#f4a261, 0)
cFailed      = color.new(#e63946, 0)
cDistortion  = color.new(#d62828, 0)
cDrift       = color.new(#6b7280, 0)
cNeutral     = color.new(#4b5563, 0)

cMemEquil  = color.new(#3a86ff, 0)
cMemCompr  = color.new(#f4d35e, 0)
cMemExpan  = color.new(#22c55e, 0)
cMemExhst  = color.new(#f4a261, 0)
cMemFailed = color.new(#e63946, 0)

cSyncStrong   = color.new(#22c55e, 0)
cSyncEquil    = color.new(#3a86ff, 0)
cSyncCompr    = color.new(#f4d35e, 0)
cSyncTrans    = color.new(#f4a261, 0)
cSyncConflict = color.new(#e63946, 0)
cSyncMixed    = color.new(#6b7280, 0)

cLqLive  = color.new(#9aa0a6, 30)
cLqTaken = color.new(#9aa0a6, 80)

// ─── HELPERS ─────────────────────────────────────────────────────────────────
clamp01(x) => math.max(0.0, math.min(1.0, x))

makeBar(score) =>
    n = math.round(score / 10)
    s = ""
    for i = 0 to 9
        s := s + (i < n ? "▰" : "▱")
    s

colorForKind(string k) =>
    c = cNeutral
    if k == "equilibrium"
        c := cMemEquil
    else if k == "compression"
        c := cMemCompr
    else if k == "expansion"
        c := cMemExpan
    else if k == "exhaustion"
        c := cMemExhst
    else if k == "failed"
        c := cMemFailed
    c

stateCompat(string a, string b) =>
    aDir = a == "TRAVERSAL" or a == "EXPANSION"
    bDir = b == "TRAVERSAL" or b == "EXPANSION"
    aQuiet = a == "COMPRESSION" or a == "DRIFT"
    bQuiet = b == "COMPRESSION" or b == "DRIFT"
    aExh = a == "EXHAUSTION"
    bExh = b == "EXHAUSTION"
    counter = (aExh and bDir) or (bExh and aDir)
    chaos = a == "DISTORTION" or b == "DISTORTION"
    bad = a == "FAILED" or b == "FAILED"
    score = 50
    if a == b
        score := 100
    else if counter
        score := 15
    else if chaos
        score := 5
    else if bad
        score := 25
    else if aDir and bDir
        score := 80
    else if aQuiet and bQuiet
        score := 75
    score

// ─── UDT: MEMORY ZONE ────────────────────────────────────────────────────────
type MemoryZone
    string kind
    float zTop
    float zBot
    int created
    int lastTouched
    int touches
    float score
    box bx

// ─── CORE: ATR + ADAPTIVE CHANNEL ────────────────────────────────────────────
atrF  = ta.atr(atrLen)
atrS  = ta.atr(atrSlow)
atrR  = atrS > 0 ? atrF / atrS : 1.0

mid   = ta.linreg(close, chanLen, 0)
dev   = ta.stdev(close, chanLen)
wMult = adaptive ? chanMult * math.max(0.6, math.min(1.6, atrR)) : chanMult
upper = mid + wMult * dev
lower = mid - wMult * dev
chW   = upper - lower
chWA  = atrF > 0 ? chW / atrF : 0
pos   = chW > 0 ? math.max(0.0, math.min(1.0, (close - lower) / chW)) : 0.5
midPos = dev > 0 ? math.max(-3, math.min(3, (close - mid) / dev)) : 0

slope    = (mid - mid[slopeWin]) / slopeWin
slopA    = atrF > 0 ? slope / atrF : 0
slopAbsA = math.abs(slopA)

// ─── BEHAVIORAL METRICS ──────────────────────────────────────────────────────
ret    = close - close[1]
retA   = atrF > 0 ? ret / atrF : 0
absRet = math.abs(retA)

body    = math.abs(close - open)
rng     = high - low
upWick  = high - math.max(close, open)
loWick  = math.min(close, open) - low
totWick = upWick + loWick
bodyRat = rng > 0 ? body / rng : 0
wickRat = rng > 0 ? totWick / rng : 0

netDisp = math.abs(close - close[effLen])
pathSum = math.sum(math.abs(ret), effLen)
efficiency = pathSum > 0 ? netDisp / pathSum : 0

impulse = absRet > 0.5 ? 1 : 0
cadence = math.sum(impulse, cadenceLen) / cadenceLen
netImp  = math.sum(retA, cadenceLen)
absImpSum = math.sum(absRet, cadenceLen)
directionality = absImpSum > 0 ? math.abs(netImp) / absImpSum : 0

slopeChange    = math.abs(slopA - slopA[slopeWin])
slopeStability = 1.0 / (1.0 + slopeChange * 5.0)

bodyAvg = ta.sma(body, 20)
bodyRel = bodyAvg > 0 ? body / bodyAvg : 1.0

wBase = ta.sma(chWA, 50)
wRel  = wBase > 0 ? chWA / wBase : 1.0

sSign = slopA > 0.02 ? 1 : slopA < -0.02 ? -1 : 0
sFlip = sSign != sSign[1] and sSign != 0 and sSign[1] != 0 ? 1 : 0
flipCount = math.sum(sFlip, behaviorLen)

absRetF  = ta.ema(absRet, 5)
absRetSm = ta.ema(absRet, 14)
fade     = absRetSm > 0 ? math.max(0.0, 1.0 - absRetF / absRetSm) : 0

rejUp = high >= upper and close < upper - 0.20 * (upper - mid)
rejDn = low  <= lower and close > lower + 0.20 * (mid - lower)
rejCnt = math.sum((rejUp or rejDn) ? 1 : 0, behaviorLen)

midX = (ta.crossover(close, mid) or ta.crossunder(close, mid)) ? 1 : 0
midCrosses = math.sum(midX, 15)

// ─── SCORES (0–100) ──────────────────────────────────────────────────────────
qualityRaw    = 0.30*slopeStability + 0.30*efficiency + 0.20*bodyRat + 0.20*directionality
qualityScore  = math.round(clamp01(qualityRaw) * 100)

widthShrink   = clamp01(1.0 - wRel)
atrShrink     = clamp01(1.0 - atrR)
bodyShrink    = clamp01(1.0 - bodyRel)
cadLow        = clamp01(1.0 - cadence)
compressRaw   = 0.30*widthShrink + 0.30*atrShrink + 0.20*bodyShrink + 0.20*cadLow
compressScore = math.round(clamp01(compressRaw) * 100)

var int compressBars = 0
compressBars := compressScore >= cThresh ? compressBars + 1 : 0

widthExpand    = clamp01(wRel - 1.0)
atrExpand      = clamp01(atrR - 1.0)
slopeAccel     = clamp01((slopAbsA - math.abs(slopA[5])) * 8)
priorCompr     = compressBars[3] >= 3 ? 1.0 : 0.4
expansionRaw   = 0.30*widthExpand + 0.25*atrExpand + 0.25*slopeAccel + 0.20*priorCompr
expansionScore = math.round(clamp01(expansionRaw) * 100)

zComp = clamp01(math.abs(midPos) / 2.5)
wComp = clamp01(wickRat / 0.65)
rComp = clamp01(rejCnt / 3.0)
fComp = clamp01(fade)
exhaustRaw    = 0.30*zComp + 0.25*wComp + 0.25*rComp + 0.20*fComp
exhaustScore  = math.round(clamp01(exhaustRaw) * 100)

// ─── STATE FLAGS ─────────────────────────────────────────────────────────────
maxPosWin = ta.highest(pos, behaviorLen)
minPosWin = ta.lowest(pos,  behaviorLen)
failedBull = maxPosWin > 0.70 and maxPosWin < 0.92 and pos < 0.50 and absRetF < absRetSm
failedBear = minPosWin < 0.30 and minPosWin > 0.08 and pos > 0.50 and absRetF < absRetSm
isFailed = failedBull or failedBear

isDistortion = flipCount >= 3 and (atrR > 1.4 or (cadence > 0.5 and directionality < 0.30))

nearMid   = math.abs(pos - 0.5) < 0.20
weakSlope = slopAbsA < 0.05
isDrift   = nearMid and weakSlope and midCrosses >= 3 and compressScore < cThresh

// ─── STATE CLASSIFIER ────────────────────────────────────────────────────────
state = "NEUTRAL"
stateColor = cNeutral
if isDistortion
    state := "DISTORTION"
    stateColor := cDistortion
else if exhaustScore >= eThresh
    state := "EXHAUSTION"
    stateColor := cExhaustion
else if isFailed
    state := "FAILED"
    stateColor := cFailed
else if expansionScore >= xThresh and atrR > 1.0
    state := "EXPANSION"
    stateColor := cExpansion
else if compressScore >= cThresh
    state := "COMPRESSION"
    stateColor := cCompression
else if qualityScore >= qThresh and slopAbsA > 0.05
    state := "TRAVERSAL"
    stateColor := cTraversal
else if isDrift
    state := "DRIFT"
    stateColor := cDrift

stateLabel = "Neutral"
if state == "TRAVERSAL"
    stateLabel := "Clean Traversal"
else if state == "EXPANSION"
    stateLabel := "Expansion Burst"
else if state == "COMPRESSION"
    stateLabel := "Compression Coil"
else if state == "EXHAUSTION"
    stateLabel := "Exhaustion"
else if state == "FAILED"
    stateLabel := "Failed Traversal"
else if state == "DISTORTION"
    stateLabel := "Volatility Distort."
else if state == "DRIFT"
    stateLabel := "Equilibrium Drift"

// ─── HTF DATA FETCH (non-repainting via [1] + lookahead_off) ─────────────────
[h1Mid, h1Up, h1Lo, h1St, h1Q, h1C, h1X, h1E, h1Sl, h1AtrR] = request.security(syminfo.tickerid, htf1Tf, [mid[1], upper[1], lower[1], state[1], qualityScore[1], compressScore[1], expansionScore[1], exhaustScore[1], slopA[1], atrR[1]], lookahead=barmerge.lookahead_off)

[h2Mid, h2Up, h2Lo, h2St, h2Q, h2C, h2X, h2E, h2Sl, h2AtrR] = request.security(syminfo.tickerid, htf2Tf, [mid[1], upper[1], lower[1], state[1], qualityScore[1], compressScore[1], expansionScore[1], exhaustScore[1], slopA[1], atrR[1]], lookahead=barmerge.lookahead_off)

// ─── FRACTAL SYNC SCORES ─────────────────────────────────────────────────────
ltfDir = slopA > 0.05  ? 1 : slopA < -0.05  ? -1 : 0
h1Dir  = h1Sl  > 0.05  ? 1 : h1Sl  < -0.05  ? -1 : 0
h2Dir  = h2Sl  > 0.05  ? 1 : h2Sl  < -0.05  ? -1 : 0

agree  = 0.0
nPairs = 0.0
if ltfDir != 0 and h1Dir != 0
    agree  := agree  + (ltfDir == h1Dir ? 1 : -1)
    nPairs := nPairs + 1
if useHtf2 and ltfDir != 0 and h2Dir != 0
    agree  := agree  + (ltfDir == h2Dir ? 1 : -1)
    nPairs := nPairs + 1
if useHtf2 and h1Dir != 0 and h2Dir != 0
    agree  := agree  + (h1Dir == h2Dir ? 1 : -1)
    nPairs := nPairs + 1
dirAlign = nPairs > 0 ? math.round(50 + 50 * agree / nPairs) : 50

sc1  = stateCompat(state, h1St)
sc2  = useHtf2 ? stateCompat(state, h2St) : 100
sc12 = useHtf2 ? stateCompat(h1St, h2St)  : 100
structAgree = useHtf2 ? math.round((sc1 + sc2 + sc12) / 3) : sc1

sim1 = math.max(0.0, 100.0 - (math.abs(qualityScore - h1Q) + math.abs(compressScore - h1C) + math.abs(expansionScore - h1X) + math.abs(exhaustScore - h1E)) / 4.0)
sim2 = useHtf2 ? math.max(0.0, 100.0 - (math.abs(qualityScore - h2Q) + math.abs(compressScore - h2C) + math.abs(expansionScore - h2X) + math.abs(exhaustScore - h2E)) / 4.0) : 100.0
rhythmSync = useHtf2 ? math.round((sim1 + sim2) / 2.0) : math.round(sim1)

conflictInt = math.max(0, math.min(100, math.round(100 - (dirAlign * 0.40 + structAgree * 0.40 + rhythmSync * 0.20))))

// ─── SYNC STATE ──────────────────────────────────────────────────────────────
counterTrend = (h1St == "EXHAUSTION" and (state == "EXPANSION" or state == "TRAVERSAL")) or (useHtf2 and h2St == "EXHAUSTION" and (state == "EXPANSION" or state == "TRAVERSAL"))

syncState = "MIXED"
syncColor = cSyncMixed
if counterTrend or dirAlign < 25 or h1St == "DISTORTION"
    syncState := "CONFLICT"
    syncColor := cSyncConflict
else if state == "COMPRESSION" and h1St == "COMPRESSION"
    syncState := "COMPR_SYNC"
    syncColor := cSyncCompr
else if (state == "DRIFT" or state == "TRAVERSAL") and h1St == "DRIFT"
    syncState := "EQUIL_ALIGN"
    syncColor := cSyncEquil
else if dirAlign >= 75 and structAgree >= 70 and (state == "TRAVERSAL" or state == "EXPANSION")
    syncState := "STRONG_SYNC"
    syncColor := cSyncStrong
else if dirAlign < 60 or structAgree < 50 or conflictInt > 50
    syncState := "TRANSITION"
    syncColor := cSyncTrans

// ─── MACRO/MICRO CONTEXT ─────────────────────────────────────────────────────
context = "Mixed"
if state == h1St and (state == "TRAVERSAL" or state == "EXPANSION") and ltfDir != 0 and ltfDir == h1Dir
    context := "Macro Aligned"
else if h1St == "COMPRESSION" and (state == "EXPANSION" or state == "TRAVERSAL")
    context := "Setup Loading"
else if (h1St == "EXPANSION" or h1St == "TRAVERSAL") and state == "EXHAUSTION"
    context := "Pullback in Trend"
else if (h1St == "EXPANSION" or h1St == "TRAVERSAL") and state == "COMPRESSION"
    context := "Consolidation"
else if h1St == "EXHAUSTION" and (state == "EXPANSION" or state == "TRAVERSAL")
    context := "Counter-Trend"
else if state == "DRIFT" and h1St == "DRIFT"
    context := "Equilibrium"
else if ltfDir != 0 and h1Dir != 0 and ltfDir != h1Dir
    context := "Direction Conflict"

// ─── CHANNEL VISUAL (LOCAL) ──────────────────────────────────────────────────
pM = plot(showChannel ? mid   : na, "Mid",   color=cMid,  linewidth=1)
pU = plot(showChannel ? upper : na, "Upper", color=cRail, linewidth=1)
pL = plot(showChannel ? lower : na, "Lower", color=cRail, linewidth=1)
fillC = not showFill ? na : color.new(stateColor, 92)
fill(pU, pL, color=fillC, title="Channel Fill")

bgcolor(showRibbon and state != "NEUTRAL" ? color.new(stateColor, 90) : na, title="State Ribbon")
barcolor(colorBars ? stateColor : na)

// ─── HTF RAILS (subtle) ──────────────────────────────────────────────────────
plot(showHtf1            ? h1Mid : na, "HTF1 Mid",   color=color.new(cMid,  60), linewidth=1, style=plot.style_circles)
plot(showHtf1            ? h1Up  : na, "HTF1 Upper", color=color.new(cRail, 60), linewidth=1, style=plot.style_circles)
plot(showHtf1            ? h1Lo  : na, "HTF1 Lower", color=color.new(cRail, 60), linewidth=1, style=plot.style_circles)
plot(showHtf2 and useHtf2? h2Mid : na, "HTF2 Mid",   color=color.new(cMid,  78), linewidth=1, style=plot.style_circles)
plot(showHtf2 and useHtf2? h2Up  : na, "HTF2 Upper", color=color.new(cRail, 78), linewidth=1, style=plot.style_circles)
plot(showHtf2 and useHtf2? h2Lo  : na, "HTF2 Lower", color=color.new(cRail, 78), linewidth=1, style=plot.style_circles)

// ─── PIVOT LIQUIDITY LINES ───────────────────────────────────────────────────
ph  = ta.pivothigh(high, pivotL, pivotR)
pl_ = ta.pivotlow (low,  pivotL, pivotR)

var line[]  hiLn = array.new<line>()
var float[] hiLv = array.new<float>()
var bool[]  hiTk = array.new<bool>()
var line[]  loLn = array.new<line>()
var float[] loLv = array.new<float>()
var bool[]  loTk = array.new<bool>()

if showZones and not na(ph)
    px = bar_index - pivotR
    ln = line.new(px, ph, bar_index, ph, color=cLqLive, width=1, extend=extend.right)
    array.push(hiLn, ln)
    array.push(hiLv, ph)
    array.push(hiTk, false)
    if array.size(hiLn) > maxZones
        line.delete(array.shift(hiLn))
        array.shift(hiLv)
        array.shift(hiTk)
if showZones and not na(pl_)
    px = bar_index - pivotR
    ln = line.new(px, pl_, bar_index, pl_, color=cLqLive, width=1, extend=extend.right)
    array.push(loLn, ln)
    array.push(loLv, pl_)
    array.push(loTk, false)
    if array.size(loLn) > maxZones
        line.delete(array.shift(loLn))
        array.shift(loLv)
        array.shift(loTk)

if showZones and array.size(hiLn) > 0
    for i = 0 to array.size(hiLn) - 1
        if not array.get(hiTk, i) and high > array.get(hiLv, i)
            array.set(hiTk, i, true)
            line.set_color(array.get(hiLn, i), cLqTaken)
            line.set_style(array.get(hiLn, i), line.style_dotted)
if showZones and array.size(loLn) > 0
    for i = 0 to array.size(loLn) - 1
        if not array.get(loTk, i) and low < array.get(loLv, i)
            array.set(loTk, i, true)
            line.set_color(array.get(loLn, i), cLqTaken)
            line.set_style(array.get(loLn, i), line.style_dotted)

// ─── MEMORY ZONES ────────────────────────────────────────────────────────────
var array<MemoryZone> zones = array.new<MemoryZone>()
var int lastSpawnExpan = -1000
var int lastSpawnCompr = -1000
var int lastSpawnEquil = -1000
var int lastSpawnExhst = -1000
var int lastSpawnFail  = -1000
var float comprHi = na
var float comprLo = na

prevState = state[1]

if state == "COMPRESSION"
    if prevState != "COMPRESSION"
        comprHi := high
        comprLo := low
    else
        comprHi := math.max(nz(comprHi, high), high)
        comprLo := math.min(nz(comprLo, low), low)

countKind(string k) =>
    n = 0
    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            z = array.get(zones, i)
            if z.kind == k
                n := n + 1
    n

opacityFor(float score) => math.max(70.0, 95.0 - score * 0.25)

spawnZone(string kind, float zTop, float zBot, float initScore) =>
    if showMemory and countKind(kind) < maxPerKind and zTop > zBot
        clr = colorForKind(kind)
        op  = opacityFor(initScore)
        bx  = box.new(bar_index, zTop, bar_index, zBot, bgcolor=color.new(clr, math.round(op)), border_color=color.new(clr, 75), border_width=1, extend=extend.right)
        z = MemoryZone.new(kind=kind, zTop=zTop, zBot=zBot, created=bar_index, lastTouched=bar_index, touches=1, score=initScore, bx=bx)
        array.push(zones, z)

if memExpanOn and prevState == "COMPRESSION" and state == "EXPANSION" and not na(comprHi) and bar_index - lastSpawnExpan >= spawnCool
    spawnZone("expansion", comprHi, comprLo, 75.0)
    lastSpawnExpan := bar_index

if memComprOn and prevState == "COMPRESSION" and state != "COMPRESSION" and compressBars[1] >= 5 and not na(comprHi) and bar_index - lastSpawnCompr >= spawnCool
    spawnZone("compression", comprHi, comprLo, 65.0)
    lastSpawnCompr := bar_index

if state != "COMPRESSION" and prevState == "COMPRESSION"
    comprHi := na
    comprLo := na

if memFailOn and state == "FAILED" and prevState != "FAILED" and bar_index - lastSpawnFail >= spawnCool
    if failedBull
        zT = ta.highest(high, behaviorLen)
        zB = zT - 0.5 * atrF
        spawnZone("failed", zT, zB, 75.0)
    else if failedBear
        zB = ta.lowest(low, behaviorLen)
        zT = zB + 0.5 * atrF
        spawnZone("failed", zT, zB, 75.0)
    lastSpawnFail := bar_index

if memEquilOn and state == "DRIFT" and prevState != "DRIFT" and bar_index - lastSpawnEquil >= spawnCool
    spawnZone("equilibrium", mid + 0.3 * atrF, mid - 0.3 * atrF, 50.0)
    lastSpawnEquil := bar_index

if memExhstOn and state == "EXHAUSTION" and prevState != "EXHAUSTION" and bar_index - lastSpawnExhst >= spawnCool
    if midPos > 0
        spawnZone("exhaustion", high, high - 0.5 * atrF, 70.0)
    else
        spawnZone("exhaustion", low + 0.5 * atrF, low, 70.0)
    lastSpawnExhst := bar_index

if array.size(zones) > 0
    for i = array.size(zones) - 1 to 0
        z = array.get(zones, i)
        touched      = high >= z.zBot and low <= z.zTop
        closedInside = close >= z.zBot and close <= z.zTop
        rejected     = touched and not closedInside
        if touched
            z.touches := z.touches + 1
            z.lastTouched := bar_index
            bonus = rejected ? rejectBonus : touchBonus
            z.score := math.min(100.0, z.score + bonus)
        z.score := z.score - decayPerBar
        if z.score < removeThresh
            box.delete(z.bx)
            array.remove(zones, i)
        else
            clr = colorForKind(z.kind)
            op  = opacityFor(z.score)
            box.set_bgcolor(z.bx, color.new(clr, math.round(op)))
            box.set_right(z.bx, bar_index)

nTotal = array.size(zones)

// ─── DASHBOARD ───────────────────────────────────────────────────────────────
tablePos = position.top_right
if dashPos == "top_left"
    tablePos := position.top_left
else if dashPos == "bottom_left"
    tablePos := position.bottom_left
else if dashPos == "bottom_right"
    tablePos := position.bottom_right

dirArrow(int d) =>
    s = "─"
    if d > 0
        s := "▲"
    else if d < 0
        s := "▼"
    s

dirColor(int d) =>
    c = cTextMute
    if d > 0
        c := cTraversal
    else if d < 0
        c := cFailed
    c

var table dash = table.new(tablePos, 3, 13, bgcolor=color.new(#0d1117, 15), border_width=1, border_color=color.new(#1f2733, 40))

if showDash and barstate.islast
    table.cell(dash, 0, 0, "STATE",      text_color=cTextDim,    text_size=size.small)
    table.cell(dash, 1, 0, stateLabel,   text_color=stateColor,  text_size=size.small)
    table.cell(dash, 2, 0, dirArrow(ltfDir), text_color=dirColor(ltfDir), text_size=size.small)

    table.cell(dash, 0, 1, "Quality",   text_color=cTextDim, text_size=size.tiny)
    table.cell(dash, 1, 1, makeBar(qualityScore),  text_color=cTraversal,   text_size=size.tiny)
    table.cell(dash, 2, 1, str.tostring(qualityScore),  text_color=cText,   text_size=size.tiny)

    table.cell(dash, 0, 2, "Compress",  text_color=cTextDim, text_size=size.tiny)
    table.cell(dash, 1, 2, makeBar(compressScore), text_color=cCompression, text_size=size.tiny)
    table.cell(dash, 2, 2, str.tostring(compressScore), text_color=cText,   text_size=size.tiny)

    table.cell(dash, 0, 3, "Expansion", text_color=cTextDim, text_size=size.tiny)
    table.cell(dash, 1, 3, makeBar(expansionScore),text_color=cExpansion,   text_size=size.tiny)
    table.cell(dash, 2, 3, str.tostring(expansionScore),text_color=cText,   text_size=size.tiny)

    table.cell(dash, 0, 4, "Exhaust",   text_color=cTextDim, text_size=size.tiny)
    table.cell(dash, 1, 4, makeBar(exhaustScore),  text_color=cExhaustion,  text_size=size.tiny)
    table.cell(dash, 2, 4, str.tostring(exhaustScore),  text_color=cText,   text_size=size.tiny)

    table.cell(dash, 0, 5, "Memory",    text_color=cTextDim, text_size=size.tiny)
    table.cell(dash, 1, 5, "active",    text_color=cTextMute,text_size=size.tiny)
    table.cell(dash, 2, 5, str.tostring(nTotal), text_color=cText, text_size=size.tiny)

    table.cell(dash, 0, 6, "SYNC",      text_color=cTextDim,  text_size=size.small)
    table.cell(dash, 1, 6, syncState,   text_color=syncColor, text_size=size.small)
    table.cell(dash, 2, 6, "",          text_size=size.small)

    table.cell(dash, 0, 7, "Dir Align", text_color=cTextMute, text_size=size.tiny)
    table.cell(dash, 1, 7, makeBar(dirAlign),     text_color=syncColor, text_size=size.tiny)
    table.cell(dash, 2, 7, str.tostring(dirAlign),     text_color=cText, text_size=size.tiny)

    table.cell(dash, 0, 8, "Struct",    text_color=cTextMute, text_size=size.tiny)
    table.cell(dash, 1, 8, makeBar(structAgree),  text_color=syncColor, text_size=size.tiny)
    table.cell(dash, 2, 8, str.tostring(structAgree),  text_color=cText, text_size=size.tiny)

    table.cell(dash, 0, 9, "Rhythm",    text_color=cTextMute, text_size=size.tiny)
    table.cell(dash, 1, 9, makeBar(rhythmSync),   text_color=syncColor, text_size=size.tiny)
    table.cell(dash, 2, 9, str.tostring(rhythmSync),   text_color=cText, text_size=size.tiny)

    table.cell(dash, 0,10, "Context",   text_color=cTextMute, text_size=size.tiny)
    table.cell(dash, 1,10, context,     text_color=cText,     text_size=size.tiny)
    table.cell(dash, 2,10, "",          text_size=size.tiny)

    table.cell(dash, 0,11, htf1Tf,      text_color=cTextMute, text_size=size.tiny)
    table.cell(dash, 1,11, h1St,        text_color=cTextDim,  text_size=size.tiny)
    table.cell(dash, 2,11, dirArrow(h1Dir), text_color=dirColor(h1Dir), text_size=size.tiny)

    table.cell(dash, 0,12, useHtf2 ? htf2Tf : "—", text_color=cTextMute, text_size=size.tiny)
    table.cell(dash, 1,12, useHtf2 ? h2St   : "—", text_color=cTextDim,  text_size=size.tiny)
    table.cell(dash, 2,12, useHtf2 ? dirArrow(h2Dir) : "—", text_color=useHtf2 ? dirColor(h2Dir) : cTextMute, text_size=size.tiny)

// ─── ALERTS ──────────────────────────────────────────────────────────────────
stateChanged = state != state[1]
alertcondition(stateChanged and state == "TRAVERSAL",   "Clean Traversal",     "vX: Clean Traversal engaged")
alertcondition(stateChanged and state == "COMPRESSION", "Compression Coil",    "vX: Compression Coil")
alertcondition(stateChanged and state == "EXPANSION",   "Expansion Burst",     "vX: Expansion Burst")
alertcondition(stateChanged and state == "EXHAUSTION",  "Exhaustion",          "vX: Exhaustion state")
alertcondition(stateChanged and state == "FAILED",      "Failed Traversal",    "vX: Failed Traversal")
alertcondition(stateChanged and state == "DISTORTION",  "Volatility Distort.", "vX: Volatility Distortion")
alertcondition(stateChanged and state == "DRIFT",       "Equilibrium Drift",   "vX: Equilibrium Drift")

syncChanged = syncState != syncState[1]
alertcondition(syncChanged and syncState == "STRONG_SYNC", "Strong Sync",      "vX: Strong fractal synchronization")
alertcondition(syncChanged and syncState == "CONFLICT",    "Strong Conflict",  "vX: Strong fractal conflict")
alertcondition(syncChanged and syncState == "COMPR_SYNC",  "Compression Sync", "vX: Multi-TF compression")

contextChanged = context != context[1]
alertcondition(contextChanged and context == "Setup Loading",     "Setup Loading",     "vX: HTF compression + LTF expansion")
alertcondition(contextChanged and context == "Counter-Trend",     "Counter-Trend",     "vX: Counter-trend impulse against HTF exhaustion")
alertcondition(contextChanged and context == "Pullback in Trend", "Pullback in Trend", "vX: LTF exhaustion inside HTF continuation")

spawnEvt = (memExpanOn and prevState == "COMPRESSION" and state == "EXPANSION") or (memFailOn and state == "FAILED" and prevState != "FAILED") or (memExhstOn and state == "EXHAUSTION" and prevState != "EXHAUSTION")
alertcondition(spawnEvt, "Memory Zone Spawned", "vX: New behavioral memory zone")
